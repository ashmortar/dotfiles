#!/bin/bash
set -eufo pipefail

echo "🚀 Installing packages..."

# --- Neovim 0.12+ (cross-platform, from GitHub releases) ---
install_neovim() {
  local current_version
  current_version=$(nvim --version 2>/dev/null | head -1 | grep -oE '[0-9]+\.[0-9]+' | head -1 || echo "0.0")
  local major minor
  major=$(echo "$current_version" | cut -d. -f1)
  minor=$(echo "$current_version" | cut -d. -f2)

  if [[ "$major" -ge 1 ]] || [[ "$major" -eq 0 && "$minor" -ge 12 ]]; then
    echo "✓ Neovim $current_version already installed"
    return
  fi

  echo "📦 Installing Neovim 0.12+..."

  {{- if eq .chezmoi.os "darwin" }}
  {{-   if eq .chezmoi.arch "arm64" }}
  local nvim_asset="nvim-macos-arm64.tar.gz"
  local nvim_dir="nvim-macos-arm64"
  {{-   else }}
  local nvim_asset="nvim-macos-x86_64.tar.gz"
  local nvim_dir="nvim-macos-x86_64"
  {{-   end }}
  {{- else if eq .chezmoi.os "linux" }}
  {{-   if eq .chezmoi.arch "arm64" }}
  local nvim_asset="nvim-linux-arm64.tar.gz"
  local nvim_dir="nvim-linux-arm64"
  {{-   else }}
  local nvim_asset="nvim-linux-x86_64.tar.gz"
  local nvim_dir="nvim-linux-x86_64"
  {{-   end }}
  {{- end }}

  local tmp_dir
  tmp_dir=$(mktemp -d)
  curl -Lo "$tmp_dir/$nvim_asset" "https://github.com/neovim/neovim/releases/latest/download/$nvim_asset"
  tar -C "$tmp_dir" -xzf "$tmp_dir/$nvim_asset"

  rm -rf ~/.local/nvim
  mv "$tmp_dir/$nvim_dir" ~/.local/nvim
  rm -rf "$tmp_dir"

  mkdir -p ~/.local/bin
  ln -sf ~/.local/nvim/bin/nvim ~/.local/bin/nvim

  echo "✓ Neovim installed to ~/.local/nvim"
}

install_neovim

# --- Clean up old Neovim plugin data ---
if [[ -d ~/.local/share/nvim/lazy ]]; then
  echo "🧹 Removing old lazy.nvim plugin data..."
  rm -rf ~/.local/share/nvim/lazy
fi

{{- if eq .chezmoi.os "darwin" }}
# macOS setup
if ! command -v brew &> /dev/null; then
  echo "📦 Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

brew bundle --file=/dev/stdin <<BREWFILE
# Core tools
brew "git"
brew "curl"
brew "wget"
brew "tmux"
brew "ripgrep"
brew "fd"
brew "fzf"
brew "eza"
brew "bat"
brew "jq"
brew "starship"
brew "zoxide"
brew "direnv"
brew "delta"
brew "zsh-syntax-highlighting"
brew "zsh-autosuggestions"
brew "tree-sitter"
brew "tree-sitter-cli"

# Fonts
cask "font-jetbrains-mono-nerd-font"

# Terminal
cask "wezterm@nightly"
BREWFILE

{{- else if eq .chezmoi.os "linux" }}
# Linux/WSL2 setup
sudo apt update && sudo apt upgrade -y
sudo apt install -y build-essential git curl wget zsh jq tmux fontconfig unzip

# Architecture detection for .deb downloads
{{- if eq .chezmoi.arch "arm64" }}
DEB_ARCH="arm64"
{{- else }}
DEB_ARCH="amd64"
{{- end }}

# ripgrep
command -v rg &>/dev/null || sudo apt install -y ripgrep

# fd
if ! command -v fd &>/dev/null && ! command -v fdfind &>/dev/null; then
  wget -q "https://github.com/sharkdp/fd/releases/download/v9.0.0/fd_9.0.0_${DEB_ARCH}.deb"
  sudo dpkg -i "fd_9.0.0_${DEB_ARCH}.deb" && rm "fd_9.0.0_${DEB_ARCH}.deb"
elif command -v fdfind &>/dev/null && ! command -v fd &>/dev/null; then
  sudo ln -sf "$(which fdfind)" /usr/local/bin/fd
fi

# fzf
command -v fzf &>/dev/null || sudo apt install -y fzf

# eza
if ! command -v eza &>/dev/null; then
  sudo mkdir -p /etc/apt/keyrings
  wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
  echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | sudo tee /etc/apt/sources.list.d/gierens.list
  sudo apt update && sudo apt install -y eza
fi

# bat
if ! command -v bat &>/dev/null && ! command -v batcat &>/dev/null; then
  sudo apt install -y bat
fi
if command -v batcat &>/dev/null && ! command -v bat &>/dev/null; then
  sudo ln -sf "$(which batcat)" /usr/local/bin/bat
fi

# starship
if ! command -v starship &>/dev/null; then
  curl -sS https://starship.rs/install.sh | sh -s -- -y
fi

# zoxide
if ! command -v zoxide &>/dev/null; then
  curl -sS https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | bash
fi

# direnv
if ! command -v direnv &>/dev/null; then
  curl -sfL https://direnv.net/install.sh | bash
fi

# delta
if ! command -v delta &>/dev/null; then
  wget -q "https://github.com/dandavison/delta/releases/download/0.18.2/git-delta_0.18.2_${DEB_ARCH}.deb"
  sudo dpkg -i "git-delta_0.18.2_${DEB_ARCH}.deb" && rm "git-delta_0.18.2_${DEB_ARCH}.deb"
fi

# tree-sitter-cli (needed for treesitter parser compilation)
if ! command -v tree-sitter &>/dev/null; then
  if command -v npm &>/dev/null; then
    npm install -g tree-sitter-cli
  elif command -v cargo &>/dev/null; then
    cargo install tree-sitter-cli
  else
    echo "⚠️  tree-sitter-cli not installed. Install npm or cargo first."
  fi
fi

# Install zsh plugins
mkdir -p ~/.local/share/zsh/plugins
[[ -d ~/.local/share/zsh/plugins/zsh-syntax-highlighting ]] || \
  git clone https://github.com/zsh-users/zsh-syntax-highlighting.git ~/.local/share/zsh/plugins/zsh-syntax-highlighting
[[ -d ~/.local/share/zsh/plugins/zsh-autosuggestions ]] || \
  git clone https://github.com/zsh-users/zsh-autosuggestions ~/.local/share/zsh/plugins/zsh-autosuggestions

{{- if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
# WSL2-specific: win32yank for clipboard
if ! command -v win32yank.exe &>/dev/null; then
  curl -sLo /tmp/win32yank.zip https://github.com/equalsraf/win32yank/releases/latest/download/win32yank-x64.zip
  unzip -p /tmp/win32yank.zip win32yank.exe > /tmp/win32yank.exe
  chmod +x /tmp/win32yank.exe
  sudo mv /tmp/win32yank.exe /usr/local/bin/
fi

# WSL2-specifc: wslu for browser integration
if ! command -v wslview &>/dev/null; then
  sudo apt install -y wslu
fi
{{- end }}
{{- end }}

# Install atuin (cross-platform)
if ! command -v atuin &>/dev/null; then
  echo "📚 Installing atuin..."
  curl --proto '=https' --tlsv1.2 -LsSf https://github.com/atuinsh/atuin/releases/latest/download/atuin-installer.sh | sh
fi

# Install tmux plugin manager
if [[ ! -d ~/.tmux/plugins/tpm ]]; then
  git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
fi

echo "✅ Package installation complete!"
