#!/bin/bash
set -eufo pipefail

echo "🔧 Setting up mise..."

# Install mise if not present
if ! command -v mise &>/dev/null; then
  curl https://mise.run | sh
fi

# Add mise to path for this script
export PATH="$HOME/.local/bin:$PATH"

# Configure global tools
mise use -g node@{{ .node_version }}
mise use -g python@{{ .python_version }}
mise use -g go@{{ .go_version }}
mise use -g rust@{{ .rust_version }}

# Install global packages after tools are ready
echo "📦 Installing global npm packages..."
mise exec -- npm install -g typescript typescript-language-server prettier eslint neovim tree-sitter-cli

echo "📦 Installing Python tools..."
mise exec -- pip install --user poetry mypy ruff pynvim

echo "✅ Mise configuration complete!"
